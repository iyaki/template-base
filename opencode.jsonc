{
	"$schema": "https://opencode.ai/config.json",
	"compaction": {
		"auto": false,
		"prune": true,
		"reserved": 0
	},
	"permission": {
		"bash": {
			"git commit*-n*": "deny",
			"git commit*--no-verify*": "deny"
		},
		"edit": {
			"lefthook.ymll": "ask",
			"opencode.jsonc": "ask",
			"logs/*": "deny",
			"/tmp/*": "allow"
		}
	},
	"agent": {
		"ralph": {
			"description": "Hands-off agent for usage with Ralph Loops",
			"mode": "primary",
			"model": "github-copilot/gpt-5.3-codex",
			"reasoningEffort": "xhigh",
			// "textVerbosity": "low",
			"tools": {
				"web-search_*": false
			},
			"permission": {
				"edit": {
					".go-arch-lint": "deny",
					".golangci.yml": "deny",
					"lefthook.ymll": "deny",
					"opencode.jsonc": "deny",
					"logs/*": "deny"
				}
			}
		}
	},
	"mcp": {
		"browser-automation": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"--network",
				"host",
				"mcp/playwright"
			],
			"enabled": true
		},
		"web-scraping": {
			"type": "local",
			"command": [
				"docker",
				"run",
				"-i",
				"--rm",
				"pyd4vinci/scrapling",
				"mcp"
			],
			"enabled": false
		},
		"tech-docs": {
			"type": "remote",
			"url": "https://mcp.context7.com/mcp",
			"enabled": true
		},
		"code-tools": {
			"type": "local",
			"command": [
				"uvx", "--from", "git+https://github.com/oraios/serena",
				"serena",
				"start-mcp-server",
				"--project-from-cwd",
				"--open-web-dashboard", "false",
				"--context", "ide"
			],
			"environment": {
				// "INTELEPHENSE_LICENSE_KEY": "{file:/home/codespace/intelephense/licence.txt}"
			},
			"enabled": false
		},
		"web-search": {
			"type": "local",
			"command": [
				"npx", "-y", "open-websearch@latest"
			],
			"environment": {
				"MODE": "stdio",
				"DEFAULT_SEARCH_ENGINE": "duckduckgo"
			},
			"enabled": true
		},
		"jam": {
			"type": "remote",
			"url": "https://mcp.jam.dev/mcp",
			"enabled": false
		},
		"code-examples": {
			"type": "remote",
			"url": "https://mcp.grep.app",
			"enabled": true
		},
		"github": {
			"type": "remote",
			"url": "https://api.githubcopilot.com/mcp/",
			"enabled": false
		},
		"public-data": {
			"type": "remote",
			"url": "https://api.datacommons.org/mcp",
			"headers": {
				"X-API-Key": "{env:DATACOMMONS_API_KEY}"
			},
			"enabled": false
		},
		"repository-context": {
			"type": "remote",
			"url": "https://gitmcp.io/docs",
			"enabled": true
		},
		"async-bash": {
				"type": "local",
				"command": ["uvx", "async-bash-mcp"],
				"enabled": false
		}
	},
	"formatter": {
  },
	"plugin": [
		"envsitter-guard@latest",
		"@slkiser/opencode-quota"
		// "opencode-mystatus",
		// "@tarquinen/opencode-dcp@latest",
		// "opencode-pty",
		// "oh-my-opencode@latest"
	],
	// "experimental": {
	// 	"quotaToast": {
	// 		"enabledProviders": [
	// 			"copilot",
	// 			// "openai",
	// 			// "google-antigravity"
	// 		]
	// 	}
	// }
}
